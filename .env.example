# Copy this file to ".env" for local use, OR add these as GitHub Secrets / your
# host's environment variables for cloud use.
#
# Use an APP PASSWORD, not your normal email password.
#   Gmail:   Google Account -> Security -> 2-Step Verification -> App passwords
#   Outlook: account.live.com/proofs/AppPassword (needs 2-step on)
#   Yahoo:   Account Security -> Generate app password

EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=youraddress@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_TO=youraddress@gmail.com

# Common SMTP hosts/ports:
#   Gmail    smtp.gmail.com        587
#   Outlook  smtp-mail.outlook.com 587
#   Yahoo    smtp.mail.yahoo.com   465
